#!/bin/bash
# ============================================================
#  🔓 最初にこれを実行 — 安全のロックをまとめて外す
#  ダウンロードしたファイルにMacが付ける「隔離マーク」を、
#  このフォルダごと一括で外します（ターミナル操作は不要）。
#  1回だけダブルクリックすればOKです。
#  ※音楽・写真などの個人データには一切触りません。
# ============================================================
cd "$(dirname "$0")"
DIR="$(cd "$(dirname "$0")" && pwd)"
clear
echo "========================================================"
echo "  🔓 安全のロックを外しています..."
echo "========================================================"
echo ""
echo "  対象フォルダ：$DIR"
echo ""

# このフォルダ内の全ファイルの隔離属性(com.apple.quarantine)を一括削除
xattr -cr "$DIR" 2>/dev/null

# .command 類に実行権限を付け直す（コピーで外れた場合の保険）
chmod +x "$DIR"/*.command 2>/dev/null
[ -f "$DIR/setup_common.sh" ] && chmod +x "$DIR/setup_common.sh" 2>/dev/null

# 確認：まだ隔離が残っているファイルが無いか
LEFT="$(xattr -r "$DIR" 2>/dev/null | grep -c "com.apple.quarantine")"

echo "  ✅ 完了しました！"
echo ""
if [ "$LEFT" = "0" ]; then
    echo "  これで、このフォルダの中のファイルは"
    echo "  警告なしでダブルクリックできるようになりました。"
else
    echo "  ほぼ完了しました（念のためもう一度この画面を閉じて、"
    echo "  もう一度だけダブルクリックすると確実です）。"
fi
echo ""
echo "  ▶ 次は「これをダブルクリック！.command」をダブルクリックして"
echo "     動画づくりを始めてください。"
echo ""
echo "  （この『最初にこれを実行』は、もう使いません）"
echo "========================================================"
echo ""
read -p "Enterで閉じる..."
